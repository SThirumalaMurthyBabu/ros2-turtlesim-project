<launch>
    <node pkg = "turtlesim" exec = "turtlesim_node"/>
    <node pkg = "turtlesim_catch_them_all" exec = "controller_exe">
        <param from = "$(find-pkg-share my_robot_bringup)/config/catch_them_all_config.yaml"/>
    </node>
    <node pkg = "turtlesim_catch_them_all" exec = "spawner_exe">
        <param from = "$(find-pkg-share my_robot_bringup)/config/catch_them_all_config.yaml"/>
    </node>
</launch>
